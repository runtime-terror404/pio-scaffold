#!/usr/bin/env python3
import os
import subprocess
import sys

def main():
    project_name = os.path.basename(os.getcwd())
    print(f"Initializing RP2350 Dual-Core Project: {project_name}...")

    # 1. Initialize standard PlatformIO project
    # We use 'pico' just to get the framework to generate the folder tree
    print("Generating PIO folder structure...")
    subprocess.run(["pio", "project", "init", "--ide", "vscode", "--board", "pico"], stdout=subprocess.DEVNULL)

    # 2. Inject the custom RP2350 configuration with USB and DAPLink environments
    print("Writing custom RP2350 platformio.ini...")
    ini_content = """[env]
platform = https://github.com/maxgerhardt/platform-raspberrypi.git
board = rpipico2
framework = arduino
board_build.core = earlephilhower
board_upload.maximum_size = 16777216
monitor_speed = 115200

; Default environment: Flashes via USB-C (1200bps touch)
[env:usb]

; Debug environment: Flashes via SWD DAPLink
[env:dap]
upload_protocol = cmsis-dap
debug_tool = cmsis-dap
"""
    with open("platformio.ini", "w") as f:
        f.write(ini_content)

    # 3. Generate the Dual-Core Boilerplate
    print("Generating dual-core src/main.cpp...")
    cpp_content = """#include <Arduino.h>

// ==========================================
// CORE 0 — runs on the first M33 core
// ==========================================
// setup(): runs once at boot — put init code here (pins, serial, peripherals)
void setup() {
}

// loop(): runs repeatedly after setup() — put your main logic here
void loop() {
}

// ==========================================
// CORE 1 — runs on the second M33 core
// ==========================================
// setup1(): runs once at boot on core 1 — init core-1 resources here
void setup1() {
}

// loop1(): runs repeatedly on core 1 — put concurrent tasks here
void loop1() {
}
"""
    # Ensure src directory exists just in case
    os.makedirs("src", exist_ok=True)
    with open("src/main.cpp", "w") as f:
        f.write(cpp_content)

    # 4. Pre-compile the framework object files
    print("Pre-compiling framework (This takes a few seconds but makes future builds instant)...")
    # We build the 'usb' env silently. It uses the cached toolchains automatically.
    subprocess.run(["pio", "run", "-e", "usb"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    print(f"\n[SUCCESS] {project_name} configured for WeAct RP2350A!")
    print("Type 'code .' to open the project.")

if __name__ == "__main__":
    main()
