#!/usr/bin/env python3
import os
import re
import glob
import subprocess
import sys

def main():
    print("Scanning for CubeMX .ioc file...")
    ioc_files = glob.glob("*.ioc")
    
    if not ioc_files:
        print("[ERROR] No .ioc file found in the current directory.")
        print("Please generate the project from CubeMX first.")
        sys.exit(1)
        
    ioc_file = ioc_files[0]
    project_name = ioc_file.replace(".ioc", "")
    print(f"Found: {ioc_file} (Project: {project_name})")

    # 1. Parse MCU from the .ioc file
    mcu_name = None
    with open(ioc_file, 'r') as f:
        for line in f:
            if line.startswith("Mcu.UserName="):
                mcu_name = line.strip().split("=")[1] # e.g., STM32F411CEUx
                break
                
    if not mcu_name:
        print("[ERROR] Could not extract MCU name from .ioc file.")
        sys.exit(1)

    print(f"Extracted MCU: {mcu_name}")

    # 2. Format it for PlatformIO generic boards
    match = re.search(r'(STM32[A-Z0-9]{6})', mcu_name)
    if match:
        clean_mcu = match.group(1)
        board_id = f"generic{clean_mcu}"
        # Extract the family for OpenOCD (e.g., "f4" from STM32F411)
        mcu_family = clean_mcu[5:7].lower()
    else:
        print("[WARNING] Unfamiliar MCU format. Defaulting to genericSTM32F411CE.")
        board_id = "genericSTM32F411CE"
        mcu_family = "f4"

    print(f"Mapped to PIO Board: {board_id}")
    print(f"Mapped to OpenOCD Target: stm32{mcu_family}x.cfg")

    # 3. Run PIO Init to generate .vscode, .pio, and standard structure
    print("\nInitializing PlatformIO project...")
    subprocess.run(["pio", "project", "init", "--ide", "vscode", "--board", board_id])

    # 4. Generate the SWO Extra Script
    print("Generating SWO Trace script...")
    # Note: We inject the dynamic {mcu_family} into the OpenOCD target and tpiu commands
    swo_script_content = f"""Import("env")

# The OpenOCD command from our previous terminal testing
openocd_cmd = 'openocd -c "debug_level 1" -f interface/stlink.cfg -f target/stm32{mcu_family}x.cfg -c "init; reset halt; stm32{mcu_family}x.tpiu configure -protocol uart -traceclk 100000000 -output /dev/stdout -formatter off; stm32{mcu_family}x.tpiu enable; itm port 0 on; resume"'

# Add it to the PlatformIO UI
env.AddCustomTarget(
    name="swo_trace",
    dependencies=None,
    actions=[openocd_cmd],
    title="Start SWO Monitor",
    description="Streams SWO debug data via OpenOCD"
)
"""
    with open("swo_trace.py", "w") as f:
        f.write(swo_script_content)

    # 5. Inject the CubeMX folder routing and framework settings
    print("Injecting CubeMX folder routing and extra scripts...")
    
    with open("platformio.ini", "r") as f:
        ini_content = f.read()

    routing_config = """[platformio]
src_dir = Core/Src
include_dir = Core/Inc

"""
    # Added extra_scripts to hook the new Python file we just created
    env_config = """
framework = stm32cube
upload_protocol = stlink
debug_tool = stlink
monitor_speed = 115200
extra_scripts = swo_trace.py
"""
    
    new_ini_content = routing_config + ini_content + env_config

    with open("platformio.ini", "w") as f:
        f.write(new_ini_content)

    print(f"\n[SUCCESS] {project_name} is fully configured for {board_id}!")
    print("Type 'code .' to open the project.")

if __name__ == "__main__":
    main()
